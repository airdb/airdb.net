---
import "../styles/global.css";
import type { LanguageOption } from "../lib/content";

type NavItem = {
  name?: string;
  url?: string;
};

const {
  title,
  description,
  globalNav = [],
  sidebarNav = [],
  languageOptions = [],
  currentPath = "/",
  htmlLang = "zh-CN",
  homePath = "/zh/",
  brandTagline = "",
  footerTitle = "",
  footerCopy = "",
  copyrightLabel = "",
  filingLabel = "",
  filingUrl = "https://beian.miit.gov.cn/",
} = Astro.props as {
  title: string;
  description?: string;
  globalNav?: NavItem[];
  sidebarNav?: NavItem[];
  languageOptions?: LanguageOption[];
  currentPath?: string;
  htmlLang?: string;
  homePath?: string;
  brandTagline?: string;
  footerTitle?: string;
  footerCopy?: string;
  copyrightLabel?: string;
  filingLabel?: string;
  filingUrl?: string;
};

function isActive(url?: string) {
  if (!url) {
    return false;
  }

  return currentPath === url || currentPath.startsWith(url.endsWith("/") ? url : `${url}/`);
}
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" />
  </head>
  <body>
    <div class="page-orbit page-orbit-left"></div>
    <div class="page-orbit page-orbit-right"></div>
    <header class="site-header">
      <div class="shell">
        <div class="header-bar">
          <a class="brand" href={homePath}>
            <span class="brand-mark">airdb</span>
          </a>
          <nav class="top-nav" aria-label="Global">
            {globalNav.map((item) => (
              <a class:list={[isActive(item.url) && "active"]} href={item.url}>
                {item.name}
              </a>
            ))}
          </nav>
          {languageOptions.length > 0 && (
            <div class="language-switch" aria-label="Language switcher">
              {languageOptions.map((item, index) => (
                <>
                  {index > 0 && <span class="language-divider">/</span>}
                  <a class:list={["language-pill", item.active && "active"]} href={item.url} hreflang={item.code}>
                    {item.label}
                  </a>
                </>
              ))}
            </div>
          )}
        </div>
      </div>
    </header>

    <main class:list={["shell", sidebarNav.length > 0 && "with-sidebar"]}>
      {sidebarNav.length > 0 && (
        <aside class="sidebar">
          <div class="sidebar-panel">
            <p class="sidebar-label">目录</p>
            <nav aria-label="Section">
              {sidebarNav.map((item) => (
                <a class:list={[isActive(item.url) && "active"]} href={item.url}>
                  {item.name}
                </a>
              ))}
            </nav>
          </div>
        </aside>
      )}

      <div class="page-content">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <div class="shell footer-shell">
        <div>
          <p class="footer-mark">airdb</p>
          <h2>{footerTitle}</h2>
        </div>
        <div class="footer-meta">
          <p>{footerCopy}</p>
        </div>
      </div>
      <div class="shell footer-compliance">
        <p>
          {copyrightLabel && <span>{copyrightLabel}</span>}
          {copyrightLabel && filingLabel && <span class="footer-separator">|</span>}
          {filingLabel && (
            <a class="filing-link" href={filingUrl} target="_blank" rel="nofollow noopener noreferrer">
              {filingLabel}
            </a>
          )}
        </p>
      </div>
    </footer>
  </body>
</html>
